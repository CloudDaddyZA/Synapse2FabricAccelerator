table pipeline_activities

	column pipeline
		dataType: string
		sourceColumn: pipeline

	column workspace
		dataType: string
		sourceColumn: workspace

	column name
		dataType: string
		sourceColumn: name

	column activity_type
		dataType: string
		sourceColumn: activity_type

	column has_retry
		dataType: string
		sourceColumn: has_retry

	column depends_on_count
		dataType: string
		sourceColumn: depends_on_count

	partition pipeline_activities = m
		mode: import
		source =
			let
			    Source = Csv.Document(File.Contents(DataFolder & "pipeline_activities.csv"),[Delimiter=",",Encoding=65001,QuoteStyle=QuoteStyle.Csv]),
			    Headers = Table.PromoteHeaders(Source,[PromoteAllScalars=true])
			in
			    Headers
