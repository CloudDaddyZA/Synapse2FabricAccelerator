table linked_services

	column name
		dataType: string
		sourceColumn: name

	column workspace
		dataType: string
		sourceColumn: workspace

	column service_type
		dataType: string
		sourceColumn: service_type

	column references_key_vault
		dataType: string
		sourceColumn: references_key_vault

	partition linked_services = m
		mode: import
		source =
			let
			    Source = Csv.Document(File.Contents(DataFolder & "linked_services.csv"),[Delimiter=",",Encoding=65001,QuoteStyle=QuoteStyle.Csv]),
			    Headers = Table.PromoteHeaders(Source,[PromoteAllScalars=true])
			in
			    Headers
