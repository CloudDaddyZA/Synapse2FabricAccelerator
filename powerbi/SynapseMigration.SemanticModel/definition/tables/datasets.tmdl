table datasets

	column name
		dataType: string
		sourceColumn: name

	column workspace
		dataType: string
		sourceColumn: workspace

	column dataset_type
		dataType: string
		sourceColumn: dataset_type

	column linked_service
		dataType: string
		sourceColumn: linked_service

	partition datasets = m
		mode: import
		source =
			let
			    Source = Csv.Document(File.Contents(DataFolder & "datasets.csv"),[Delimiter=",",Encoding=65001,QuoteStyle=QuoteStyle.Csv]),
			    Headers = Table.PromoteHeaders(Source,[PromoteAllScalars=true])
			in
			    Headers
