table spark_pools

	column name
		dataType: string
		sourceColumn: name

	column workspace
		dataType: string
		sourceColumn: workspace

	column node_size
		dataType: string
		sourceColumn: node_size

	column node_size_family
		dataType: string
		sourceColumn: node_size_family

	column node_count
		dataType: string
		sourceColumn: node_count

	column autoscale_enabled
		dataType: string
		sourceColumn: autoscale_enabled

	column min_nodes
		dataType: string
		sourceColumn: min_nodes

	column max_nodes
		dataType: string
		sourceColumn: max_nodes

	column auto_pause_enabled
		dataType: string
		sourceColumn: auto_pause_enabled

	column auto_pause_minutes
		dataType: string
		sourceColumn: auto_pause_minutes

	column spark_version
		dataType: string
		sourceColumn: spark_version

	column library_count
		dataType: string
		sourceColumn: library_count

	measure 'Spark Pool Count' = COUNTROWS('spark_pools')

	partition spark_pools = m
		mode: import
		source =
			let
			    Source = Csv.Document(File.Contents(DataFolder & "spark_pools.csv"),[Delimiter=",",Encoding=65001,QuoteStyle=QuoteStyle.Csv]),
			    Headers = Table.PromoteHeaders(Source,[PromoteAllScalars=true])
			in
			    Headers
