table fabric_recommendations

	column artifact
		dataType: string
		sourceColumn: artifact

	column fabric_target
		dataType: string
		sourceColumn: fabric_target

	partition fabric_recommendations = m
		mode: import
		source =
			let
			    Source = Csv.Document(File.Contents(DataFolder & "fabric_recommendations.csv"),[Delimiter=",",Encoding=65001,QuoteStyle=QuoteStyle.Csv]),
			    Headers = Table.PromoteHeaders(Source,[PromoteAllScalars=true])
			in
			    Headers
